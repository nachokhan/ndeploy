N8N_DEV_URL=http://localhost:5678
N8N_DEV_API_KEY=dev_api_key
N8N_PROD_URL=http://localhost:5679
N8N_PROD_API_KEY=prod_api_key
# Optional fallback for `ndeploy credentials update --fill`
# N8N workflow webhook URL that returns credential data by requested ids
# N8N_DEV_CREDENTIAL_EXPORT_URL=https://your-dev/webhook/credential-export
# Bearer token used to call that webhook
# N8N_DEV_CREDENTIAL_EXPORT_TOKEN=super_secret_token
# Optional symmetric fallback when using `ndeploy credentials update --fill --side target`
# N8N_PROD_CREDENTIAL_EXPORT_URL=https://your-prod/webhook/credential-export
# N8N_PROD_CREDENTIAL_EXPORT_TOKEN=super_secret_token
