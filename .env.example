# Alternative runtime config.
# Preferred runtime config lives in ~/.ndeploy/profiles.json
# See ./profiles.example.json for the expected format.

N8N_SOURCE_URL=http://localhost:5678
N8N_SOURCE_API_KEY=source_api_key
N8N_TARGET_URL=http://localhost:5679
N8N_TARGET_API_KEY=target_api_key
# Optional fallback for `ndeploy credentials fetch`
# N8N workflow webhook URL that returns credential data by requested ids
# N8N_SOURCE_CREDENTIAL_EXPORT_URL=https://your-source/webhook/credential-export
# Bearer token used to call that webhook
# N8N_SOURCE_CREDENTIAL_EXPORT_TOKEN=super_secret_token
# Optional symmetric fallback when fetching target credential snapshots
# N8N_TARGET_CREDENTIAL_EXPORT_URL=https://your-target/webhook/credential-export
# N8N_TARGET_CREDENTIAL_EXPORT_TOKEN=super_secret_token
